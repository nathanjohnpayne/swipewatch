#!/usr/bin/env bash
# check_no_forbidden_top_level_dirs
# Verifies no forbidden top-level directories exist that would duplicate or conflict
# with the standard structure (e.g., tool-instructions/, ai-rules/).
# Exit 0 = pass, Exit 1 = fail.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# Directories that must never exist at repo root.
# These names conflict with the standard or indicate fragmented instructions.
FORBIDDEN_DIRS=(
  "tool-instructions"
  "ai-rules"
  "agent-config"
  "llm-rules"
  "prompts"
  "ai-instructions"
  "agent-instructions"
  "cursor-rules"
  "claude-rules"
)

FAILED=0

for dir in "${FORBIDDEN_DIRS[@]}"; do
  if [[ -d "$REPO_ROOT/$dir" ]]; then
    echo "FAIL: Forbidden top-level directory found: $dir"
    FAILED=1
  fi
done

if [[ $FAILED -eq 1 ]]; then
  echo "check_no_forbidden_top_level_dirs: FAILED"
  exit 1
fi

echo "check_no_forbidden_top_level_dirs: PASSED — no forbidden top-level directories found"
exit 0
