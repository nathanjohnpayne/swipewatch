#!/usr/bin/env bash
# check_dist_not_modified
# Verifies that existing dist/ files were not directly modified in the current commit.
# Uses --diff-filter=M to detect modifications only (not additions like .gitkeep).
# Exit 0 = pass, Exit 1 = fail.

set -euo pipefail

# Allow override via environment variable for compliance commits or intentional builds
if [[ "${SKIP_DIST_CHECK:-}" == "1" ]]; then
  echo "check_dist_not_modified: SKIPPED (SKIP_DIST_CHECK=1)"
  exit 0
fi

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

# If dist/ doesn't exist, nothing to check
if [[ ! -d "$REPO_ROOT/dist" ]]; then
  echo "check_dist_not_modified: SKIPPED — no dist/ directory found"
  exit 0
fi

# Check if we have at least one prior commit to diff against
if ! git rev-parse HEAD~1 &>/dev/null; then
  echo "check_dist_not_modified: SKIPPED — no prior commit to diff against (initial commit)"
  exit 0
fi

# Check for modifications to existing dist/ files only (not new additions)
MODIFIED=$(git diff --name-only --diff-filter=M HEAD~1 HEAD -- dist/ 2>/dev/null)

if [[ -n "$MODIFIED" ]]; then
  echo "FAIL: Direct modification of dist/ detected. dist/ must be generated by the build system only."
  echo "$MODIFIED" | while IFS= read -r file; do
    echo "  Modified: $file"
  done
  echo "check_dist_not_modified: FAILED"
  exit 1
fi

echo "check_dist_not_modified: PASSED — no direct modifications to dist/"
exit 0
